# ─────────────────────────────────────────────────────────────
# DevDeck — exemplo de variáveis de ambiente
# Copie para `.env.local` e preencha com seus valores reais.
# NUNCA commite `.env.local` — ele já está no .gitignore.
# ─────────────────────────────────────────────────────────────

# Banco de dados (Supabase Postgres)
# Pooler (transações): use na DATABASE_URL com ?pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
# Conexão direta (usada pelo Prisma em migrations e seed)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Supabase — Auth + DB
NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua_anon_key_aqui"
# Apenas server-side (seed, admin). Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY="sua_service_role_key_aqui"

# OpenAI (opcional — geração de quizzes a partir de posts e quiz diário)
# Se ausente, o app usa bibliotecas de fallback.
OPENAI_API_KEY="sk-..."

# Senha das contas de teste criadas pelo seed.
# Defina ANTES de rodar `npx prisma db seed`.
SEED_DEFAULT_PASSWORD="escolha_uma_senha_segura"

# URL pública do app (usada em links de e-mail, OAuth, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Opcionais (Fase 3 do roadmap) ──────────────────────────

# Rate limiting com Upstash Redis. Se ausentes, o app roda sem limite
# (útil em dev local). Configure em produção.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Segredo para proteger o endpoint de cron do quiz diário.
# Gere com: `openssl rand -hex 32`
CRON_SECRET=""
