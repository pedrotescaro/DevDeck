# ─────────────────────────────────────────────────────────────
# DevDeck — exemplo de variáveis de ambiente
# Copie para `.env.local` e preencha com seus valores reais.
# NUNCA commite `.env.local` — ele já está no .gitignore.
# ─────────────────────────────────────────────────────────────

# Banco de dados (Supabase Postgres)
# Pooler (transações): use na DATABASE_URL com ?pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
# Conexão direta (usada pelo Prisma em migrations e seed)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Supabase — Auth + DB
NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua_anon_key_aqui"
# Apenas server-side (seed, admin). Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY="sua_service_role_key_aqui"

# Configuração de IA para Quizzes (opcional — geração de quizzes a partir de posts e quiz diário)
# Se ausente, o app usa bibliotecas de fallback.
# Provedores suportados: gemini | groq | openai | ollama (se vazio, auto-detecta por chaves)
AI_PROVIDER="gemini"
# Chave de API do Google Gemini (Recomendado - Gratuito 1.5 Flash)
GEMINI_API_KEY="AIzaSy..."
# Chave de API do Groq (Llama 3.1)
GROQ_API_KEY="gsk_..."
# Chave de API da OpenAI (GPT-4o-mini)
OPENAI_API_KEY="sk-..."
# Nome do modelo padrão (opcional, sobrescreve o padrão do provedor selecionado)
AI_MODEL=""

# Configurações do Ollama (Local)
OLLAMA_API_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5-coder"

# Senha das contas de teste criadas pelo seed.
# Defina ANTES de rodar `npx prisma db seed`.
SEED_DEFAULT_PASSWORD="escolha_uma_senha_segura"

# URL pública do app (usada em links de e-mail, OAuth, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev local (Windows/antivírus): se login/registro retornar "fetch failed",
# defina como true. Nunca use em produção.
SUPABASE_SSL_INSECURE="false"

# ── Opcionais (Fase 3 do roadmap) ──────────────────────────

# Rate limiting com Upstash Redis. Se ausentes, o app roda sem limite
# (útil em dev local). Configure em produção.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Segredo para proteger o endpoint de cron do quiz diário.
# Gere com: `openssl rand -hex 32`
CRON_SECRET=""

# Configurable Endpoints (Hardcoding improvements)
NEXT_PUBLIC_AVATAR_API_URL="https://api.dicebear.com/9.x/pixel-art/svg"
PISTON_API_URL="https://emkc.org/api/v2/piston/execute"
OPENAI_API_BASE_URL="https://api.openai.com/v1"

# GitHub (análise de repositórios no Ducky)
# Token opcional (Personal Access Token). Sem ele: apenas repositórios públicos,
# com limite baixo (60 req/hora por IP). Com ele: repositórios privados do dono
# do token e limite de 5000 req/hora. Crie em: GitHub > Settings > Developer settings > Tokens
GITHUB_TOKEN=""

